{
  "manifest_version": 3,
  "name": "IPTV Stream Injector",
  "version": "1.0",
  "description": "Play 742 sports channels (beIN, ESPN, DAZN, Sky, BT Sport, NBA, NFL) directly in browser",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://xp1.tv/*",
    "http://*.xp1.tv/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "IPTV Stream Injector"
  },
  "icons": {
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
